# Never commit real secrets.
PERPLEXITY_API_KEY=replace_with_new_key

# Models
PERPLEXITY_DEFAULT_MODEL=sonar-pro
PERPLEXITY_DEEP_MODEL=sonar-deep-research
PERPLEXITY_DEEP_SEARCH_PREMIUM_LABEL=premium_expensive
ENABLE_PREMIUM_RESEARCH_TOOLS=false

# Cost estimation fallback when the provider does not return exact cost.
PERPLEXITY_ESTIMATED_RAW_SEARCH_COST_USD=0.005
PERPLEXITY_ESTIMATED_QUICK_SEARCH_COST_USD=0.01
PERPLEXITY_ESTIMATED_DEEP_SEARCH_COST_USD=0.03
PERPLEXITY_RAW_SEARCH_MAX_RESULTS=10

# Research mode policy
RESEARCH_DEFAULT_MODE=auto
RESEARCH_AUTO_MIN_SEARCHES=3
RESEARCH_AUTO_SOFT_TARGET_SEARCHES=6
RESEARCH_AUTO_MAX_SEARCHES=8
RESEARCH_QUICK_MAX_SEARCHES=4
RESEARCH_STANDARD_MAX_SEARCHES=8
RESEARCH_DEEP_MAX_SEARCHES=15
RESEARCH_EXHAUSTIVE_MAX_SEARCHES=40
RESEARCH_DEFAULT_EXECUTION_COST_CAP_USD=0.04

# Budget guardrails
BUDGET_SOFT_LIMIT_USD=6
BUDGET_HARD_LIMIT_USD=9

# Caching
CACHE_ENABLED=true
CACHE_DIR=.cache
CACHE_TTL_HOURS=168

MCP_STATELESS_HTTP=true
MCP_JSON_RESPONSE=false
RESEARCH_MCP_HTTP_HOST=127.0.0.1
RESEARCH_MCP_HTTP_PORT=8000
RESEARCH_MCP_HTTP_PATH=/mcp
RESEARCH_MCP_PUBLIC_BASE_URL=
AGENCY_MCP_HTTP_HOST=127.0.0.1
AGENCY_MCP_HTTP_PORT=8001
AGENCY_MCP_HTTP_PATH=/mcp
AGENCY_MCP_PUBLIC_BASE_URL=

# Networking
REQUEST_TIMEOUT_SECONDS=30
REQUEST_MAX_RETRIES=2
DEFAULT_MAX_OUTPUT_TOKENS=1200
DEFAULT_DEEP_MAX_OUTPUT_TOKENS=2400

# Optional: allow the agency MCP to enrich company analysis through the research MCP flow.
AGENCY_ENABLE_EXTERNAL_RESEARCH=false
AGENCY_EXTERNAL_RESEARCH_DEFAULT_MODE=auto
AGENCY_EXTERNAL_RESEARCH_MAX_MODE=standard

# Optional / future: Google Places integration requires separate Google Cloud billing.
# GOOGLE_MAPS_API_KEY=replace_with_google_maps_key
# GOOGLE_PLACES_LANGUAGE_CODE=pt-BR
# GOOGLE_PLACES_REGION_CODE=BR
